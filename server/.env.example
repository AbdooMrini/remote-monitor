# ===========================================
# Remote Monitor — Server Environment Config
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

NODE_ENV=production

# HTTP / HTTPS
PORT=443
HTTP_PORT=80

# SSL Certificates (absolute paths)
SSL_KEY_PATH=/etc/ssl/private/server.key
SSL_CERT_PATH=/etc/ssl/certs/server.crt

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_64_CHARS
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=ANOTHER_STRONG_SECRET_FOR_REFRESH
JWT_REFRESH_EXPIRES_IN=7d

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=monitor_user
DB_PASSWORD=STRONG_DB_PASSWORD_HERE
DB_NAME=remote_monitor
DB_POOL_SIZE=10

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://yourdomain.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/server.log

# Frontend base URL
FRONTEND_URL=https://yourdomain.com
